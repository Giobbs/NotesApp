<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="Impostazioni"
        app:titleCentered="true"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="56dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tema"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingBottom="8dp"/>

        <RadioGroup
            android:id="@+id/radioTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/themeSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistema"/>

            <RadioButton
                android:id="@+id/themeLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chiaro"/>

            <RadioButton
                android:id="@+id/themeDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scuro"/>

        </RadioGroup>
        <!-- =========================
             AGGREGAZIONE
        ========================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aggregazione"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <RadioGroup
            android:id="@+id/radioAggregation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/aggNone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nessuna"/>

            <RadioButton
                android:id="@+id/aggTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Per Tag"/>

            <RadioButton
                android:id="@+id/aggDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Per Data"/>
        </RadioGroup>

        <!-- =========================
             FILTRO DATA
        ========================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Periodo"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <RadioGroup
            android:id="@+id/radioDateRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/date7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ultimi 7 giorni"/>

            <RadioButton
                android:id="@+id/date30"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ultimo mese"/>

            <RadioButton
                android:id="@+id/date365"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ultimo anno"/>
        </RadioGroup>

        <!-- =========================
             PIN SECURITY
        ========================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sicurezza PIN"
            android:textStyle="bold"
            android:textSize="16sp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/editPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Imposta PIN (4-6 cifre)"
            android:inputType="numberPassword"/>

        <Button
            android:id="@+id/btnSavePin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salva PIN"/>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>